        "encoding": "str，可选，默认 utf-8",
        "case_sensitive": "bool，可选，默认 false"
      },
      "output": "dict，统一返回 success/data 或 success/error",
      "demo_param_schema": {
        "enabled": true,
        "fields": [
          {
            "name": "file_path",
            "required": true,
            "sensitive": false,
            "description": "待搜索文件路径",
            "value_type": "string",
