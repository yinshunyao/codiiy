          {
            "name": "context_lines",
            "required": false,
            "sensitive": false,
            "description": "上下文行数",
            "value_type": "int",
            "default": 3
          },
          {
            "name": "encoding",
            "required": false,
            "sensitive": false,
            "description": "文件编码",
            "value_type": "string",
            "default": "utf-8"
          },
          {
            "name": "case_sensitive",
            "required": false,
            "sensitive": false,
            "description": "是否大小写敏感",
