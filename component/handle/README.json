{
  "directory": "component/handle",
  "description": "执行与处理模块，提供文件读取、检索、元信息查询、鼠标操作、Python 依赖包管理与 macOS 终端会话能力。",
  "components": [
    {
      "component_key": "handle.file_reader_component",
      "component_dir": "component/handle/file_reader_component",
      "description": "文件读取组件，负责文件内容读取、行区间读取、关键字/正则检索和文件统计。",
      "default_enabled": true,
      "supported_systems": ["macos", "linux", "windows"],
      "system_param_schema": {
        "enabled": false,
        "fields": []
      }
    },
    {
      "component_key": "handle.mouse_action_component",
      "component_dir": "component/handle/mouse_action_component",
      "description": "鼠标操作组件，提供单击、双击、移动、滚动、拖拽与位置查询等常用桌面鼠标能力。",
      "default_enabled": true,
      "supported_systems": ["macos", "linux", "windows"],
      "system_param_schema": {
        "enabled": false,
        "fields": []
      },
      "system_permission_schema": {
        "enabled": true,
        "permissions": [
          {
            "key": "macos.accessibility",
            "name": "macOS 辅助功能权限",
            "required": true,
            "description": "鼠标自动化操作依赖系统辅助功能授权。",
            "grant_guide": "系统设置 -> 隐私与安全性 -> 辅助功能，为 Python/终端应用开启授权。",
            "grant_url": ""
          }
        ]
      }
    },
    {
      "component_key": "handle.python_package_component",
      "component_dir": "component/handle/python_package_component",
      "description": "Python 依赖包管理组件，提供依赖包查询、安装与卸载能力。",
      "default_enabled": true,
      "supported_systems": ["macos", "linux", "windows"],
      "system_param_schema": {
        "enabled": false,
        "fields": []
      },
      "system_permission_schema": {
        "enabled": true,
        "permissions": [
          {
            "key": "python.venv_write",
            "name": "Python 运行环境可写权限",
            "required": true,
            "description": "安装/卸载依赖时，当前 Python 环境与 site-packages 目录需要可写。",
            "grant_guide": "建议在非 root 用户下使用虚拟环境运行 Django；避免 sudo 直接运行。",
            "grant_url": ""
          },
          {
            "key": "python.pip_cache_write",
            "name": "pip 缓存目录可写权限",
            "required": false,
            "description": "用于提升 pip 安装性能；不可写时通常可继续安装但会出现告警。",
            "grant_guide": "确保用户对 ~/.cache/pip 或等效缓存目录有写权限。",
            "grant_url": ""
          }
        ]
      }
    },
    {
      "component_key": "handle.macos_terminal_component",
      "component_dir": "component/handle/macos_terminal_component",
      "description": "macOS 终端组件，提供多 shell 会话创建、命令执行、输出读取与会话关闭能力。",
      "default_enabled": true,
      "supported_systems": ["macos"],
      "system_param_schema": {
        "enabled": false,
        "fields": []
      },
      "system_permission_schema": {
        "enabled": true,
        "permissions": [
          {
            "key": "macos.terminal.execution",
            "name": "macOS 终端执行权限",
            "required": true,
            "description": "通过 shell 子进程执行命令并读取标准输出。",
            "grant_guide": "确保 Python 运行用户具备终端命令执行权限，并可访问目标工作目录。",
            "grant_url": ""
          }
        ]
      }
    }
  ],
  "functions": [
    {
      "path": "component.handle.read_file",
      "component_key": "handle.file_reader_component",
      "description": "读取整个文件内容并返回文件元信息。",
      "input": {
        "file_path": "str，文件路径",
        "encoding": "str，可选，默认 utf-8"
      },
      "output": "dict，统一返回 success/data 或 success/error",
      "demo_param_schema": {
        "enabled": true,
        "fields": [
          {
            "name": "file_path",
            "required": true,
            "sensitive": false,
            "description": "待读取文件路径",
            "value_type": "string",
            "default": "readme.md"
          },
          {
            "name": "encoding",
            "required": false,
            "sensitive": false,
            "description": "文件编码",
            "value_type": "string",
            "default": "utf-8"
          }
        ]
      }
    },
    {
      "path": "component.handle.read_lines",
      "component_key": "handle.file_reader_component",
      "description": "读取文件指定行范围（包含结束行）。",
      "input": {
        "file_path": "str，文件路径",
        "start_line": "int，开始行号（从 1 开始）",
        "end_line": "int，结束行号（包含）",
        "encoding": "str，可选，默认 utf-8"
      },
      "output": "dict，统一返回 success/data 或 success/error",
      "demo_param_schema": {
        "enabled": true,
        "fields": [
          {
            "name": "file_path",
            "required": true,
            "sensitive": false,
            "description": "待读取文件路径",
            "value_type": "string",
            "default": "readme.md"
          },
          {
            "name": "start_line",
            "required": true,
            "sensitive": false,
            "description": "开始行号（从 1 开始）",
            "value_type": "int",
            "default": 1
          },
          {
            "name": "end_line",
            "required": true,
            "sensitive": false,
            "description": "结束行号（包含）",
            "value_type": "int",
            "default": 20
          },
          {
            "name": "encoding",
            "required": false,
            "sensitive": false,
            "description": "文件编码",
            "value_type": "string",
            "default": "utf-8"
          }
        ]
      }
    },
    {
      "path": "component.handle.search_keyword",
      "component_key": "handle.file_reader_component",
      "description": "按关键字搜索文件并返回上下文。",
